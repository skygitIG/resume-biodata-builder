---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="ResuBio — Free Resume & Biodata Builder">

  <!-- Hero -->
  <section class="bg-gradient-to-br from-indigo-600 via-indigo-700 to-purple-800 text-white py-24 px-4 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold mb-4 leading-tight">
      Resume & Marriage Biodata<br />Builder — 100% Free
    </h1>
    <p class="text-lg text-indigo-200 mb-10 max-w-xl mx-auto">
      Fill a form, get a beautiful PDF. No sign-up. No watermark. No payment. Ever.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href={`${base}resume`}
        class="bg-white text-indigo-700 px-8 py-3 rounded-xl font-semibold hover:bg-indigo-50 transition shadow-md">
        Build My Resume
      </a>
      <a href={`${base}biodata`}
        class="bg-purple-500 text-white border border-purple-300 px-8 py-3 rounded-xl font-semibold hover:bg-purple-400 transition shadow-md">
        Create Biodata
      </a>
    </div>
  </section>

  <!-- Builder Cards -->
  <section class="max-w-5xl mx-auto px-4 py-16 grid sm:grid-cols-2 gap-8">

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 hover:shadow-md transition-shadow flex flex-col">
      <div class="text-4xl mb-4">📄</div>
      <h2 class="text-2xl font-bold text-gray-900 mb-2">Resume Builder</h2>
      <p class="text-gray-500 mb-6 text-sm leading-relaxed">
        For job seekers. Add your work experience, education, skills and download a clean one-page resume instantly.
      </p>
      <ul class="text-sm text-gray-500 space-y-2 mb-8">
        <li class="flex items-center gap-2"><span class="text-indigo-500">✓</span> Professional template</li>
        <li class="flex items-center gap-2"><span class="text-indigo-500">✓</span> Live preview while you type</li>
        <li class="flex items-center gap-2"><span class="text-indigo-500">✓</span> Download as PDF — free</li>
        <li class="flex items-center gap-2"><span class="text-indigo-500">✓</span> No account needed</li>
      </ul>
      <a href={`${base}resume`}
        class="mt-auto block text-center bg-indigo-600 text-white px-6 py-3 rounded-xl font-semibold hover:bg-indigo-700 transition">
        Build My Resume →
      </a>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 hover:shadow-md transition-shadow flex flex-col">
      <div class="text-4xl mb-4">💑</div>
      <h2 class="text-2xl font-bold text-gray-900 mb-2">Marriage Biodata</h2>
      <p class="text-gray-500 mb-6 text-sm leading-relaxed">
        For matrimonial use. Include personal, family, education, horoscope and partner preference details.
      </p>
      <ul class="text-sm text-gray-500 space-y-2 mb-8">
        <li class="flex items-center gap-2"><span class="text-purple-500">✓</span> Traditional elegant design</li>
        <li class="flex items-center gap-2"><span class="text-purple-500">✓</span> Family & horoscope sections</li>
        <li class="flex items-center gap-2"><span class="text-purple-500">✓</span> Download as PDF — free</li>
        <li class="flex items-center gap-2"><span class="text-purple-500">✓</span> No account needed</li>
      </ul>
      <a href={`${base}biodata`}
        class="mt-auto block text-center bg-purple-600 text-white px-6 py-3 rounded-xl font-semibold hover:bg-purple-700 transition">
        Create Biodata →
      </a>
    </div>

  </section>

  <!-- Why ResuBio -->
  <section class="bg-gray-50 border-t border-gray-200 py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-12">Why ResuBio?</h2>
      <div class="grid sm:grid-cols-3 gap-10">
        <div>
          <div class="text-4xl mb-3">⚡</div>
          <h3 class="font-semibold text-gray-900 mb-2">Ready in Minutes</h3>
          <p class="text-gray-500 text-sm">Fill in your details, your document is ready. No complex setup.</p>
        </div>
        <div>
          <div class="text-4xl mb-3">🆓</div>
          <h3 class="font-semibold text-gray-900 mb-2">Always Free</h3>
          <p class="text-gray-500 text-sm">No subscriptions, no hidden fees, no premium tier. Download unlimited times.</p>
        </div>
        <div>
          <div class="text-4xl mb-3">🔒</div>
          <h3 class="font-semibold text-gray-900 mb-2">Private by Design</h3>
          <p class="text-gray-500 text-sm">Your data never leaves your device. Nothing is stored on any server.</p>
        </div>
      </div>
    </div>
  </section>

</Layout>
