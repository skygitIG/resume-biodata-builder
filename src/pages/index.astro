---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="QuickResume — Free Resume Builder">

  <!-- Hero -->
  <section class="bg-gradient-to-br from-indigo-600 via-indigo-700 to-indigo-900 text-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 flex flex-col lg:flex-row items-center gap-12">

      <!-- Left: Text -->
      <div class="flex-1 text-center lg:text-left">
        <span class="inline-block bg-indigo-500 text-indigo-100 text-xs font-semibold px-3 py-1 rounded-full mb-4 uppercase tracking-wide">
          100% Free · No Sign-up
        </span>
        <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-4">
          Build a Professional<br />Resume in Minutes
        </h1>
        <p class="text-indigo-200 text-lg mb-8 max-w-lg mx-auto lg:mx-0">
          Fill in your details, get a polished one-page resume instantly.
          Download as PDF — free, forever, no watermark.
        </p>
        <a href={`${base}resume`}
          class="inline-block bg-white text-indigo-700 font-semibold px-8 py-3 rounded-xl shadow-lg hover:bg-indigo-50 transition text-lg">
          Build My Resume →
        </a>
        <p class="mt-4 text-indigo-300 text-sm">No account needed · Download unlimited times</p>
      </div>

      <!-- Right: Hero Image -->
      <div class="flex-1 flex justify-center lg:justify-end">
        <div class="relative">
          <div class="absolute inset-0 bg-indigo-500 rounded-2xl opacity-20 blur-3xl scale-110"></div>
          <img
            src={`${base}images/hero.webp`}
            alt="Professional resume building"
            class="relative rounded-2xl shadow-2xl w-full max-w-md object-cover"
            style="aspect-ratio: 4/3;"
            loading="eager"
          />
        </div>
      </div>

    </div>
  </section>

  <!-- How It Works -->
  <section class="max-w-5xl mx-auto px-4 py-16 text-center">
    <h2 class="text-3xl font-bold text-gray-900 mb-3">Ready in 3 simple steps</h2>
    <p class="text-gray-500 mb-12">No learning curve. Just fill, preview, and download.</p>
    <div class="grid sm:grid-cols-3 gap-8">
      {[
        { step: '1', title: 'Fill Your Details', desc: 'Add your work experience, education, skills, and a quick summary.' },
        { step: '2', title: 'See Live Preview', desc: 'Your resume updates in real time as you type — no guesswork.' },
        { step: '3', title: 'Download PDF', desc: 'One click. Clean, ATS-friendly PDF — no watermark, no fees.' },
      ].map(s => (
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 hover:shadow-md transition">
          <div class="w-12 h-12 bg-indigo-600 text-white rounded-xl flex items-center justify-center text-xl font-bold mx-auto mb-4">
            {s.step}
          </div>
          <h3 class="font-semibold text-gray-900 text-lg mb-2">{s.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{s.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Features with Images -->
  <section class="bg-gray-50 border-t border-gray-200 py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Why QuickResume?</h2>
      <div class="grid sm:grid-cols-3 gap-8">

        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden hover:shadow-md transition">
          <img
            src={`${base}images/feature-fast.webp`}
            alt="Fast resume creation"
            class="w-full h-44 object-cover"
            loading="lazy"
          />
          <div class="p-6">
            <h3 class="font-bold text-gray-900 text-lg mb-2">⚡ Lightning Fast</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Your resume is ready in under 5 minutes. Live preview updates as you type.
            </p>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden hover:shadow-md transition">
          <img
            src={`${base}images/feature-free.webp`}
            alt="Completely free"
            class="w-full h-44 object-cover"
            loading="lazy"
          />
          <div class="p-6">
            <h3 class="font-bold text-gray-900 text-lg mb-2">🆓 Always Free</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              No subscriptions. No premium tier. No hidden charges. Download as many times as you want.
            </p>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden hover:shadow-md transition">
          <img
            src={`${base}images/feature-private.webp`}
            alt="Private and secure"
            class="w-full h-44 object-cover"
            loading="lazy"
          />
          <div class="p-6">
            <h3 class="font-bold text-gray-900 text-lg mb-2">🔒 Fully Private</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Your data never leaves your device. Nothing is stored on any server.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA Bottom -->
  <section class="max-w-3xl mx-auto px-4 py-20 text-center">
    <h2 class="text-3xl font-bold text-gray-900 mb-4">Ready to build your resume?</h2>
    <p class="text-gray-500 mb-8">Join thousands who've landed jobs with QuickResume. It's free.</p>
    <a href={`${base}resume`}
      class="inline-block bg-indigo-600 text-white font-semibold px-10 py-4 rounded-xl shadow-lg hover:bg-indigo-700 transition text-lg">
      Build My Resume — It's Free →
    </a>
  </section>

</Layout>
